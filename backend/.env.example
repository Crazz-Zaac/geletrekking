# ==========================================
# MONGODB CONFIGURATION
# ==========================================
# MongoDB credentials (no URL encoding needed - done automatically!)
MONGO_USERNAME=your_mongo_username
MONGO_PASSWORD=your_mongo_password
MONGO_HOST=mongo                    # Use 'mongo' for Docker, 'localhost' for local dev
MONGO_PORT=27017
MONGO_DATABASE=geletrekking
MONGO_AUTH_SOURCE=admin

# MongoDB initialization (for Docker only)
MONGO_INITDB_ROOT_USERNAME=your_mongo_username
MONGO_INITDB_ROOT_PASSWORD=your_mongo_password

# ==========================================
# MONGO EXPRESS (Database Admin UI)
# ==========================================
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin123
ME_CONFIG_MONGODB_SERVER=mongo
ME_CONFIG_MONGODB_PORT=27017

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:3000

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long

# Superadmin credentials (created on first run)
SUPERADMIN_EMAIL=superadmin@yourdomain.com
SUPERADMIN_PASSWORD=your_secure_password

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# Gmail app password: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
