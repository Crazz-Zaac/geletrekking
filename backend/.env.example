# ==========================================
# MONGODB CONFIGURATION
# ==========================================
# MongoDB credentials (no URL encoding needed!)
MONGO_USERNAME=sherap
MONGO_PASSWORD=P@ssw0rd!
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DATABASE=geletrekking
MONGO_AUTH_SOURCE=admin

# MongoDB initialization (for Docker)
MONGO_INITDB_ROOT_USERNAME=sherap
MONGO_INITDB_ROOT_PASSWORD=P@ssw0rd!

# ==========================================
# MONGO EXPRESS (Database Admin UI)
# ==========================================
ME_CONFIG_BASICAUTH_USERNAME=sherap
ME_CONFIG_BASICAUTH_PASSWORD=sherap123
# Mongo Express connection to MongoDB with credentials
ME_CONFIG_MONGODB_URL=mongodb://sherap:P%40ssw0rd%21@mongo:27017/?authSource=admin

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://geletracking.com
FRONTEND_URL=http://localhost:3000

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long
SUPERADMIN_EMAIL=superadmin@geletrekking.com
SUPERADMIN_PASSWORD=your_superadmin_password_here

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
EMAIL_USER=your_email_address_here
EMAIL_PASS=your_email_password_or_app_specific_password_here


# ==========================================
# GOOGLE PLACES API CONFIGURATION
# ==========================================
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_PLACE_ID=google_place_id_for_geletrekking_location_here

# ==========================================
# CONTACT FORM & CAPTCHA CONFIGURATION
# ==========================================
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=YOUR_SERVER_SECRET
CAPTCHA_REQUIRED=true
CONTACT_MIN_FILL_MS=2500
CONTACT_DUPLICATE_WINDOW_MS=600000
TRUST_PROXY=true
RISK_ANALYSIS_ENABLED=true
RISK_USE_REDIS=true
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
RISK_BLOCK_THRESHOLD=100
RISK_BLOCK_DURATION_MS=1800000
RISK_REQUEST_WINDOW_MS=60000
RISK_REQUEST_WINDOW_LIMIT=80
RISK_CONTACT_WINDOW_MS=300000
RISK_CONTACT_WINDOW_LIMIT=8
RISK_PROFILE_TTL_MS=86400000